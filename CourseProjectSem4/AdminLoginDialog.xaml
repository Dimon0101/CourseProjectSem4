<Window x:Class="CourseProjectSem4.AdminLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вхід адміністратора"
        Width="320" Height="195"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <StackPanel Margin="28,22">
        <TextBlock Text="Введіть пароль адміністратора"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="#1A2A4A" Margin="0,0,0,14"/>

        <Border BorderBrush="#CDD6E0" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,10">
            <PasswordBox x:Name="PasswordBox"
                         BorderThickness="0" Padding="10,8"
                         FontSize="13"
                         KeyDown="PasswordBox_KeyDown"/>
        </Border>

        <TextBlock x:Name="ErrorLabel"
                   Foreground="#E74C3C" FontSize="11"
                   Margin="0,0,0,10" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Скасувати" Width="95" Height="34"
                    Margin="0,0,8,0" Click="Cancel_Click"
                    Background="#E0E0E0" Foreground="#444"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="Увійти" Width="95" Height="34"
                    Background="#1A2A4A" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Login_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
