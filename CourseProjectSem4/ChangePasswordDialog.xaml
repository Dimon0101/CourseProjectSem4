<Window x:Class="CourseProjectSem4.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Зміна пароля адміністратора"
        Width="340" Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4F8">

    <StackPanel Margin="28,22">
        <TextBlock Text="Зміна пароля" FontSize="15" FontWeight="Bold"
                   Foreground="#1A2A4A" Margin="0,0,0,18"/>

        <TextBlock Text="Поточний пароль" FontSize="12"
                   Foreground="#666" Margin="0,0,0,5"/>
        <Border BorderBrush="#CDD6E0" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,12">
            <PasswordBox x:Name="CurrentPasswordBox"
                         BorderThickness="0" Padding="10,8" FontSize="13"/>
        </Border>

        <TextBlock Text="Новий пароль" FontSize="12"
                   Foreground="#666" Margin="0,0,0,5"/>
        <Border BorderBrush="#CDD6E0" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,12">
            <PasswordBox x:Name="NewPasswordBox"
                         BorderThickness="0" Padding="10,8" FontSize="13"/>
        </Border>

        <TextBlock Text="Повторіть новий пароль" FontSize="12"
                   Foreground="#666" Margin="0,0,0,5"/>
        <Border BorderBrush="#CDD6E0" BorderThickness="1"
                CornerRadius="6" Margin="0,0,0,12">
            <PasswordBox x:Name="ConfirmPasswordBox"
                         BorderThickness="0" Padding="10,8" FontSize="13"/>
        </Border>

        <TextBlock x:Name="ErrorLabel" Foreground="#E74C3C"
                   FontSize="11" Margin="0,0,0,10" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Скасувати" Width="95" Height="34"
                    Margin="0,0,8,0" Click="Cancel_Click"
                    Background="#E0E0E0" Foreground="#444"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="Змінити" Width="95" Height="34"
                    Background="#1A2A4A" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Save_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
